# TailorMade Backend — Required Environment Variables
# Copy to .env and fill in real values

# fal.ai — image generation
FAL_KEY="add yours"

# Anthropic — content safety + scene planning
ANTHROPIC_API_KEY=add yours

# Firebase — auth + Firestore
FIREBASE_SERVICE_ACCOUNT_PATH=.add yours
FIREBASE_PROJECT_ID="tailormade-coloring-book"

# Cloudflare R2 — image/PDF storage (S3-compatible)
R2_ACCOUNT_ID=fuck you 
R2_ACCESS_KEY_ID=what about my 
R2_SECRET_ACCESS_KEY=hot chili pepper water
R2_BUCKET_NAME=tailormadecoloringbook
R2_PUBLIC_URL=https://pub-you are gay

# App
APP_ENV=development

# Clerk Auth
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/create
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/create
CLERK_WEBHOOK_SECRET=
VITE_CLERK_PUBLISHABLE_KEY=
# Replicate (FLUX image generation)
REPLICATE_API_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Resend
RESEND_API_KEY=
